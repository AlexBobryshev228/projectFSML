import QtQuick
import QtQuick.Controls

ApplicationWindow {
    visible: true
    visibility: Window.Maximized   // окно сразу на весь экранс (если сразу делать фулскрин у меня лагает поэтому так и тоже кайф)
    title: "Muscle Viewer"

    Image {
        anchors.fill: parent
        source: "qrc:/assets/Силуэты-мышц-человека-на-черном-фоне.svg"

        fillMode: Image.Stretch    //changed by fedya (растягивает на всё окно)
    }
}
